# ─── Magicthon environment ──────────────────────────────────────────
# Copy this file to `.env.local` and fill in keys as you sign up for each
# service. The API endpoints fall back to mock mode for any service whose
# keys are missing, so you can wire them one at a time.
#
# DO NOT COMMIT .env.local — it's already in .gitignore by default.

# ─── Anthropic (Claude vision) ──────────────────────────────────────
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Cloudinary (image storage) ─────────────────────────────────────
# Get keys at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Neon (Postgres) ────────────────────────────────────────────────
# Get connection string at: https://console.neon.tech/
# Example: postgresql://user:pass@ep-abc-123.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ─── Pusher (realtime) ──────────────────────────────────────────────
# Get keys at: https://dashboard.pusher.com/
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
# These two are public — Vite injects them into the frontend
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=
